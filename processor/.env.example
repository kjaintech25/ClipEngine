# Supabase: the URL is the same as the frontend .env.local. The service-role key
# is NOT the anon key. Grab it from:
#   https://supabase.com/dashboard/project/xqcnbpiexojncxicrtji/settings/api-keys
# Copy the "service_role" key (NOT "anon" or "publishable"). It's a long JWT.
SUPABASE_URL=https://xqcnbpiexojncxicrtji.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# OpenAI (for Whisper transcription only): https://platform.openai.com/api-keys
OPENAI_API_KEY=
